{
  "name": "elder-care-coordinator",
  "private": false,
  "version": "0.1.0",
  "description": "Local-first elder care coordination for meds, appointments, insurance drafts, and emergency packets.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/copy-404.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pages-preview": "http-server docs -p 4173 -c-1",
    "preview": "vite preview",
    "smoke": "bash scripts/smoke.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.33.1-dev45.0",
    "@tanstack/react-query": "^5.100.9",
    "age-encryption": "^0.3.0",
    "idb": "^8.0.3",
    "libsodium-wrappers-sumo": "^0.8.4",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite-plugin-pwa": "^1.3.0",
    "yjs": "^13.6.30",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
